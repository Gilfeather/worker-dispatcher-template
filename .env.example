# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/worker_dispatcher

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Google Cloud Platform Configuration
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json

# Amazon Marketing Cloud Configuration
AMC_CLIENT_ID=your_amc_client_id
AMC_CLIENT_SECRET=your_amc_client_secret
AMC_REGION=us-east-1

# Worker Configuration
WORKER_NAME=worker-1
WORKER_CAPABILITIES=general,data-processing,file-processing
API_BASE_URL=http://localhost:8000

# Application Configuration
LOG_LEVEL=INFO
DEBUG=false

# Security Configuration
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090